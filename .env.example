# HouseFlow — Environment Variables
# Copy to .env in prod/ and preprod/ directories on the VM

# ── Database ──
DB_USER=houseflow
DB_PASSWORD=CHANGE_ME

# ── JWT (minimum 32 characters) ──
JWT_KEY=CHANGE_ME_MINIMUM_32_CHARS_SECRET_KEY
JWT_ISSUER=https://api.houseflow.rouss.be
JWT_AUDIENCE=https://houseflow.rouss.be

# ── CORS (comma-separated origins) ──
CORS_ORIGINS=https://houseflow.rouss.be

# ── Public API URL (used by frontend) ──
API_PUBLIC_URL=https://api.houseflow.rouss.be

# ── Image tag (set by CI/CD) ──
IMAGE_TAG=latest
